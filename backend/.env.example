APP_NAME=Printer Monitor
HOST=127.0.0.1
PORT=8000

# Values supplied by the infrastructure team
SNMP_COMMUNITY=public
SNMP_PORT=161
DEFAULT_NETWORK=10.119.35
# วงเครือข่ายทั้งหมดที่ต้องการสแกน คั่นด้วย , (ถ้าไม่ตั้งจะใช้ค่าเดียวกับ DEFAULT_NETWORK)
DEFAULT_NETWORKS=10.119.34,10.119.35,10.119.43
SCAN_START=1
SCAN_END=254

# Automatic scan interval in seconds
POLL_INTERVAL=180
STATUS_POLL_INTERVAL=30
